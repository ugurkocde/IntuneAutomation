{
  "variables": {
    "logVerbose": false,
    "runbookType": "PowerShell",
    "scriptUri": "https://raw.githubusercontent.com/ugurkocde/IntuneAutomation/main/scripts/devices/create-app-based-groups.ps1",
    "logProgress": false
  },
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "identity": {
        "type": "SystemAssigned"
      },
      "name": "[parameters('automationAccountName')]",
      "location": "[parameters('location')]",
      "apiVersion": "2023-11-01",
      "type": "Microsoft.Automation/automationAccounts",
      "properties": {
        "sku": {
          "name": "Basic"
        }
      }
    },
    {
      "name": "[concat(parameters('automationAccountName'), '/', parameters('runbookName'))]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
      ],
      "apiVersion": "2023-11-01",
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "properties": {
        "logVerbose": "[variables('logVerbose')]",
        "runbookType": "[variables('runbookType')]",
        "description": "[parameters('runbookDescription')]",
        "publishContentLink": {
          "uri": "[variables('scriptUri')]"
        },
        "logProgress": "[variables('logProgress')]"
      }
    }
  ],
  "parameters": {
    "runbookDescription": {
      "type": "string",
      "defaultValue": "This script queries Intune-managed devices to identify which applications are installed,",
      "metadata": {
        "description": "Description of the runbook"
      }
    },
    "automationAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure Automation Account. If it does not exist in the selected resource group, it will be created with a system-assigned managed identity."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the runbook deployment"
      }
    },
    "runbookName": {
      "type": "string",
      "defaultValue": "create-app-based-groups",
      "metadata": {
        "description": "Name for the new runbook (will be created in the Automation Account)"
      }
    }
  },
  "outputs": {
    "deploymentInstructions": {
      "type": "string",
      "value": "Runbook created and published successfully! If the runbook content appears empty, manually import from the source URL provided in the outputs. Next steps: 1) Assign required Microsoft Graph permissions to the Automation Account's system-assigned Managed Identity, 2) Test the runbook."
    },
    "automationAccountName": {
      "type": "string",
      "value": "[parameters('automationAccountName')]"
    },
    "runbookUrl": {
      "type": "string",
      "value": "[concat('https://portal.azure.com/#@', subscription().tenantId, '/resource/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.Automation/automationAccounts/', parameters('automationAccountName'), '/runbooks/', parameters('runbookName'))]"
    },
    "runbookName": {
      "type": "string",
      "value": "[parameters('runbookName')]"
    },
    "scriptSourceUrl": {
      "type": "string",
      "value": "[variables('scriptUri')]"
    }
  },
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#"
}
